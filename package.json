{
  "name": "discord-rotom-bot",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "type": "module",
  "engines": {
    "node": ">=16.17.0",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "start": "wrangler dev",
    "dev": "wrangler dev",
    "format": "prettier --cache --write src",
    "format:check": "prettier --check src",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "deploy": "wrangler deploy",
    "register-commands": "tsx tools/register-commands.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "author": "lacolaco",
  "license": "MIT",
  "dependencies": {
    "cli-table3": "^0.6.5",
    "discord-interactions": "^4.0.0",
    "hono": "^4.0.0",
    "toucan-js": "^4.1.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.2",
    "@cloudflare/workers-types": "^4.20230914.0",
    "@eslint/js": "^10.0.1",
    "discord-api-types": "^0.38.0",
    "eslint": "^10.2.0",
    "prettier": "^3.0.3",
    "tsx": "^4.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3",
    "wrangler": "^4.0.0"
  }
}
